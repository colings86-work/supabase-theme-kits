{
  "manifest_version": 3,
  "version": "1.0.0",
  "name": "Supabase — Classic Dark",
  "description": "Slate-tinted dark theme with Studio-style active tab and brand-green underline accents.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "theme": {
    "images": {
      "theme_frame": "images/theme_frame.png",
      "theme_toolbar": "images/theme_toolbar.png",
      "theme_ntp_background": "images/theme_ntp_background.png"
    },
    "colors": {
      "frame":                       [15, 17, 21],
      "frame_inactive":              [12, 14, 18],
      "frame_incognito":             [8, 10, 14],
      "frame_incognito_inactive":    [6, 8, 12],
      "toolbar":                     [23, 26, 32],
      "tab_text":                    [250, 250, 250],
      "tab_background_text":         [130, 135, 145],
      "tab_background_text_inactive":[95, 100, 110],
      "bookmark_text":               [175, 180, 190],
      "ntp_background":              [15, 17, 21],
      "ntp_text":                    [250, 250, 250],
      "ntp_link":                    [62, 207, 142],
      "button_background":           [23, 26, 32],
      "omnibox_background":          [18, 20, 26],
      "omnibox_text":                [250, 250, 250]
    },
    "tints": {
      "buttons":           [-1, -1, 0.85],
      "frame":             [-1, -1, -1],
      "background_tab":    [-1, -1, -1]
    },
    "properties": {
      "ntp_background_alignment": "bottom"
    }
  }
}
